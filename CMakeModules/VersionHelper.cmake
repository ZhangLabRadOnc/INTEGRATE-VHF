if (EXISTS "${CMAKE_SOURCE_DIR}/VERSION")
    file(STRINGS "${CMAKE_SOURCE_DIR}/VERSION" VERSION_FULL LIMIT_COUNT 1)
    string(REGEX MATCH "([0-9]+[a-zA-Z]*)\\.([0-9]+[a-zA-Z]*)\\.([0-9]+[a-zA-Z]*)" VERSION_MATCH "${VERSION_FULL}")
    set(VERSION_MAJOR "${CMAKE_MATCH_1}")
    set(VERSION_MINOR "${CMAKE_MATCH_2}")
    set(VERSION_PATCH "${CMAKE_MATCH_3}")
else ()
    set(VERSION_MAJOR 0)
    set(VERSION_MINOR 0)
    set(VERSION_PATCH 0)
endif ()
